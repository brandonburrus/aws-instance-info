{
  "name": "aws-instance-info",
  "description": "Retrieve meta-info for AWS EC2, RDS, and ElastiCache such as size, memory, and more",
  "version": "1.0.0",
  "author": "Brandon Burrus <brandon@burrus.io>",
  "license": "MIT",
  "keywords": [
    "aws",
    "ec2",
    "instance",
    "metadata",
    "details",
    "information",
    "meta-information"
  ],
  "homepage": "https://awsinstanceinfo.brandonburrus.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brandonburrus/aws-instance-info.git"
  },
  "bugs": {
    "url": "https://github.com/brandonburrus/aws-instance-info/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./async": {
      "import": "./dist/index.async.js",
      "types": "./dist/index.async.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "pretest": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky",
    "lint": "biome check",
    "format": "biome format",
    "format:fix": "biome format --write",
    "docgen": "typedoc"
  },
  "lint-staged": {
    "*.ts": [
      "biome check --write --staged",
      "vitest related --passWithNoTests --run"
    ],
    "*.json": ["biome check --write --staged"]
  },
  "commitlint": {
    "extends": ["@commitlint/config-conventional"]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@vitest/coverage-v8": "^4.0.13",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "msw": "^2.12.10",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.14",
    "typedoc-github-theme": "^0.3.1",
    "typescript": "^5.8.3",
    "vitest": "^4.0.13"
  },
  "dependencies": {
    "lru-cache": "^11.2.2",
    "make-synchronous": "^2.1.0",
    "node-html-parser": "^7.1.0"
  }
}
